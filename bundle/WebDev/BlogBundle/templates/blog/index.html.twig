{% extends '@WebDevBlog/layout.html.twig' %}

{% block content %}

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <p class="mb-0">Blogs</p>
            <button
                    class="btn btn-primary btn-sm"
                    onclick="window.location.href='{{ path('blog_new') }}'">
                New Blog
            </button>
        </div>

        <div class="border-bottom px-3 py-2 flex align-items-center ">
            {{ form_start(filterForm, {
                attr: { class: 'row g-2 align-items-end' }
            }) }}

            <div class="col-md-6">
                {{ form_widget(filterForm.title, {
                    attr: {
                        class: 'form-control',
                        placeholder: 'Search blogs...'
                    }
                }) }}
            </div>

            <div class="col-md-3">
                {{ form_widget(filterForm.status, {
                    attr: {
                        class: 'form-select'
                    }
                }) }}
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm w-100" type="submit">
                    Filter
                </button>

                <a class="btn btn-outline-secondary btn-sm w-100" href="{{ path('blog_index') }}">
                    Reset
                </a>
            </div>

            {{ form_end(filterForm) }}
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                <tr>
                    <th scope="col" class="px-3">Title</th>
                    <th scope="col" class="text-center">Status</th>
                    <th scope="col" class="text-center">Created</th>
                    <th scope="col" class="text-center">Action</th>
                </tr>
                </thead>
                <tbody>
                {% for blog in blogs %}
                    <tr>
                        <td class="w-100 px-3">
                            <a href="{{ path('blog_show', {'slug': blog.slug}) }}">
                                {{ blog.title }}
                            </a>
                        </td>

                        <td class="text-nowrap px-5">
                            {{ blog.status.value }}
                        </td>

                        <td class="text-nowrap px-5">
                            {{ blog.createdAt|date('Y-m-d H:i') }}
                        </td>

                        <td class="text-end px-3">
                            <div class="d-flex justify-content-end gap-2">
                                <a
                                        class="btn btn-secondary btn-sm"
                                        href="{{ path('blog_edit', {'slug': blog.slug}) }}">
                                    Edit
                                </a>
                                <a
                                        class="btn btn-danger btn-sm"
                                        href="{{ path('blog_delete', {'slug': blog.slug}) }}"
                                        onclick="return confirm('Are you sure you want to delete this blog?');"
                                >
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {{ knp_pagination_render(blogs, '@WebDevBlog/pagination/bootstrap_custom.html.twig') }}
        </div>
    </div>

{% endblock %}